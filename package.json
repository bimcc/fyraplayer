{
  "name": "fyraplayer",
  "version": "1.0.0",
  "description": "Modern, extensible low-latency web player (WebRTC, LL-HLS, WS+WASM) with plugin/middleware architecture.",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./plugins/engines": {
      "import": "./dist/plugins/engines/index.js",
      "types": "./dist/plugins/engines/index.d.ts"
    },
    "./plugins/metadata": {
      "import": "./dist/plugins/metadata/index.js",
      "types": "./dist/plugins/metadata/index.d.ts"
    },
    "./plugins/ui-components": {
      "import": "./dist/plugins/ui-components.js",
      "types": "./dist/plugins/ui-components.d.ts"
    },
    "./plugins/metrics": {
      "import": "./dist/plugins/metrics.js",
      "types": "./dist/plugins/metrics.d.ts"
    },
    "./plugins/performance": {
      "import": "./dist/plugins/performance.js",
      "types": "./dist/plugins/performance.d.ts"
    },
    "./plugins/panoramalite": {
      "import": "./dist/plugins/panoramalite.js",
      "types": "./dist/plugins/panoramalite.d.ts"
    },
    "./plugins/reconnect": {
      "import": "./dist/plugins/reconnect.js",
      "types": "./dist/plugins/reconnect.d.ts"
    },
    "./plugins/recording-api": {
      "import": "./dist/plugins/recording.js",
      "types": "./dist/plugins/recording.d.ts"
    },
    "./plugins/diagnostics": {
      "import": "./dist/plugins/diagnostics.js",
      "types": "./dist/plugins/diagnostics.d.ts"
    },
    "./plugins/auth": {
      "import": "./dist/plugins/auth.js",
      "types": "./dist/plugins/auth.d.ts"
    },
    "./plugins/storage": {
      "import": "./dist/plugins/storage.js",
      "types": "./dist/plugins/storage.d.ts"
    },
    "./techs/wsRaw/demuxer": {
      "import": "./dist/techs/wsRaw/demuxer.js",
      "types": "./dist/techs/wsRaw/demuxer.d.ts"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "build:release": "pnpm build && pnpm bundle:iife",
    "check:public-api": "tsc -p tsconfig.public-api.json",
    "check:exports": "pnpm build && node checks/export-contract.mjs",
    "check:release": "pnpm exec jest --runInBand && pnpm check:public-api && pnpm check:exports && pnpm check:sources && pnpm build:release",
    "check:sources": "node checks/sources-contract.mjs",
    "serve:fmp4-fixture": "node checks/ffmpeg-fmp4-fixture.mjs",
    "long-run:browser": "node checks/browser-long-run.mjs",
    "long-run:assert": "node checks/browser-long-run-assert.mjs",
    "bundle:examples": "esbuild examples/app.ts --bundle --outfile=examples/bundle.js --platform=browser --format=esm",
    "bundle:iife": "esbuild src/iife.ts --bundle --outfile=dist/fyraplayer.iife.js --platform=browser --format=iife --global-name=FyraPlayerSDK",
    "bundle:examples:watch": "esbuild examples/app.ts --bundle --outfile=examples/bundle.js --platform=browser --format=esm --watch",
    "dev": "concurrently \"pnpm bundle:examples:watch\" \"pnpm serve:examples\"",
    "serve:examples": "npx http-server examples -p 5173 -c-1",
    "dev:vite": "vite --config vite.config.ts",
    "dev:vite:host": "vite --config vite.config.ts --host --port 3000",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "dashjs": "^5.1.0",
    "hls.js": "^1.6.15",
    "mp4box": "^0.5.4",
    "mpegts.js": "^1.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "esbuild": "^0.19.12",
    "fast-check": "^4.5.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.4.19"
  }
}
